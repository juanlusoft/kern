# Runtime config
KERN_RUNTIME_CONFIG_PATH=./runtime.installation.numa.example.json
KERN_EVIDENCE_FILE_PATH=./evidence.numa-smoke.jsonl

# Model endpoint used by qwen-orchestrator. Fill outside Git.
KERN_MODEL_BASE_URL=REEMPLAZAR
KERN_MODEL_NAME=kern-numa
KERN_MODEL_API_KEY=

# Numa PostgreSQL read-only connection. Fill outside Git.
NUMA_PGHOST=REEMPLAZAR
NUMA_PGPORT=5432
NUMA_PGDATABASE=REEMPLAZAR
NUMA_PGUSER=kern_ro
NUMA_PGPASSWORD=REEMPLAZAR
NUMA_PGSSLMODE=prefer
NUMA_PGSTATEMENT_TIMEOUT_MS=5000
NUMA_PGAPPNAME=kern-numa-smoke

# Spark / Open WebUI must forward this header to Kern.
ENABLE_FORWARD_USER_INFO_HEADERS=true
