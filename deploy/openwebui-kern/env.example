OPENWEBUI_CONTAINER_NAME=openwebui-numa
OPENWEBUI_HOST_BIND=127.0.0.1
OPENWEBUI_HOST_PORT=3001
OPENWEBUI_DATA_DIR=/opt/kern/companies/numa/openwebui/data
KERN_DOCKER_NETWORK=kern_numa_internal

OPENAI_API_BASE_URLS=http://kern-numa:8787/v1
OPENAI_API_KEYS=dummy
WEBUI_NAME=Kern
ENABLE_SIGNUP=false

# Generate per installation with: openssl rand -hex 32
# Store the real .env with mode 0600. Do not commit it.
WEBUI_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET
