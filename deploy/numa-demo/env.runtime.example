# Copy to deploy/numa-demo/env.runtime and fill outside Git.

# Qwen/OpenAI-compatible endpoint reachable from the kern-numa container.
KERN_MODEL_BASE_URL=http://host.docker.internal:8002/v1/chat/completions
KERN_MODEL_NAME=kern-vl
KERN_MODEL_API_KEY=

# Numa PostgreSQL read-only connection reachable from the kern-numa container.
NUMA_PGHOST=numa-dev-pg
NUMA_PGPORT=5432
NUMA_PGDATABASE=REEMPLAZAR
NUMA_PGUSER=kern_ro
NUMA_PGPASSWORD=REEMPLAZAR
NUMA_PGSSLMODE=prefer
NUMA_PGSTATEMENT_TIMEOUT_MS=5000
NUMA_PGAPPNAME=kern-numa-demo
