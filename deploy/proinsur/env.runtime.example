# Copy to env.runtime, keep it outside Git, and replace every marker.

# OpenAI-compatible model endpoint reachable from the Kern container.
KERN_MODEL_BASE_URL=REEMPLAZAR_CON_ENDPOINT_REAL
KERN_MODEL_NAME=REEMPLAZAR_CON_MODELO_REAL
KERN_MODEL_API_KEY=REEMPLAZAR_CON_SECRETO_REAL

# Proinsur PostgreSQL connection for its dedicated read-only role.
# The NUMA_ prefix is the current adapter contract; it does not identify the company.
NUMA_PGHOST=REEMPLAZAR_CON_HOST_REAL
NUMA_PGPORT=5432
NUMA_PGDATABASE=REEMPLAZAR_CON_BASE_REAL
NUMA_PGUSER=kern_ro
NUMA_PGPASSWORD=REEMPLAZAR_CON_SECRETO_REAL
NUMA_PGSSLMODE=require
NUMA_PGSTATEMENT_TIMEOUT_MS=5000
NUMA_PGAPPNAME=kern-proinsur
